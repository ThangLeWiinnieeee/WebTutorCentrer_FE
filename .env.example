# URL gốc của API backend, PHẢI có hậu tố /api.
# Dev:  http://localhost:5002/api  (gọi thẳng BE)
# Prod: /api                       (gọi qua proxy rewrite của Vercel → cookie refresh thành first-party)
VITE_API_BASE_URL=http://localhost:5002/api

# CHỈ đặt khi FE gọi API qua proxy (VITE_API_BASE_URL=/api) → socket không suy ra được host,
# nên phải trỏ thẳng BE. Bỏ trống ở localhost (socket tự suy từ VITE_API_BASE_URL).
# Prod: https://<ten-app-render>.onrender.com
VITE_SOCKET_URL=

# Google OAuth Client ID (giống GOOGLE_CLIENT_ID bên backend)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
